{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/v1/(.*)$", "dest": "/api/proxy.js" },
    { "src": "^/health$", "dest": "/api/proxy.js" },
    { "src": "^/api/health$", "dest": "/api/proxy.js" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
