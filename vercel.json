{
  "version": 2,
  "builds": [
    {
      "src": "functions/proxy.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "^/v1/(.*)$", "dest": "/functions/proxy.js" },
    { "src": "^/health$", "dest": "/functions/proxy.js" },
    { "src": "^/api/health$", "dest": "/functions/proxy.js" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
